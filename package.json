{
  "name": "kimi-code-desktop",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.1.7",
  "description": "Kimi Code 桌面应用 / Kimi Code Desktop App",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "desktop": "npm run desktop:dev",
    "desktop:dev": "tauri dev",
    "desktop:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-release.ps1",
    "desktop:bundle": "npm run release:msi",
    "build": "tsc -b && vite build",
    "check": "npm run release:preflight",
    "check:quick": "node scripts/check-quick.mjs",
    "lint": "biome check --write scripts biome.json vitest.config.ts vite.config.ts",
    "lint:check": "biome check scripts biome.json vitest.config.ts vite.config.ts",
    "release:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-preflight.ps1",
    "release:msi": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-msi.ps1",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "cursor:acp-milestone0": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-cursor-acp-milestone0.ps1",
    "cursor:acp-milestone0:dry": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-cursor-acp-milestone0.ps1 -DryRun",
    "cursor:acp-milestone0:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-cursor-acp-milestone0.ps1",
    "cursor:acp-milestone0:verify:dry": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-cursor-acp-milestone0.ps1 -DryRun",
    "cursor:acp-milestone0:verify:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-cursor-acp-milestone0.ps1 -RunCommands",
    "smoke:acp": "node scripts/acp-smoke.mjs",
    "smoke:mcp": "node scripts/smoke-mcp-tool.mjs",
    "smoke:skill": "node scripts/smoke-skill.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "tauri": "tauri",
    "tauri:dev": "npm run desktop:dev",
    "tauri:build": "npm run release:msi",
    "tauri:build:raw-msi": "tauri build --bundles msi",
    "tauri:build:nsis": "tauri build --bundles nsis",
    "version:sync": "node scripts/sync-version.js",
    "version:set": "node scripts/sync-version.js"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/iosevka": "^5.2.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/api": "^2",
    "ai": "^5.0.99",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^8.0.2",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-scan": "^0.4.3",
    "shiki": "^3.20.0",
    "sonner": "^2.0.7",
    "streamdown": "^1.6.10",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-md5": "^0.8.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "6.0.3",
    "smol-toml": "^1.5.2",
    "typescript": "~5.9.3",
    "ultracite": "^7.1.1",
    "vite": "^7.2.4",
    "vitest": "^4.1.7"
  }
}
